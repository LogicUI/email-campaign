# =============================================================================
# Test Environment Variables
# =============================================================================
# This file is used for running integration tests with Vitest.
# =============================================================================

# -----------------------------------------------------------------------------
# Test Database
# -----------------------------------------------------------------------------

# Test PostgreSQL connection string (in-memory or Docker container)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:postgres@127.0.0.1:54322/emailai_test
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/emailai_test

# -----------------------------------------------------------------------------
# Test Authentication
# -----------------------------------------------------------------------------

# Test secret key for NextAuth.js (DO NOT use in production)
AUTH_SECRET=test-auth-secret-for-testing-only-do-not-use-in-production

# Test Google OAuth credentials (DO NOT use in production)
AUTH_GOOGLE_ID=test-google-client-id
AUTH_GOOGLE_SECRET=test-google-client-secret

# Test application URL
NEXTAUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Test External API Keys (Mocked in tests)
# -----------------------------------------------------------------------------

# These are placeholder keys for tests - actual API calls are mocked
OPENAI_API_KEY=test-openai-key-do-not-use-in-production
ANTHROPIC_API_KEY=test-anthropic-key-do-not-use-in-production
GOOGLE_AI_API_KEY=test-google-ai-key-do-not-use-in-production
DEEPSEEK_API_KEY=test-deepseek-key-do-not-use-in-production

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------

NODE_ENV=test
