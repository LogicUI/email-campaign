{
  "name": "emailai-prototype",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "dev": "bun run clean && portless run next dev",
    "build": "bun run clean && bun --bun next build",
    "start": "bun --bun next start --hostname 127.0.0.1",
    "preview": "bun run clean && bun --bun next build && bun --bun next start --hostname 127.0.0.1 --port 3001",
    "lint": "next lint",
    "lint:unused": "knip-bun --include files,exports",
    "prepare": "husky",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:ci": "node ./node_modules/vitest/vitest.mjs run --coverage --reporter=verbose",
    "test:integration": "node ./node_modules/vitest/vitest.mjs run --dir=app/tests/api-integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "bun run test && bun run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "@notionhq/client": "^5.13.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/nextjs": "^10.45.0",
    "@tanstack/react-query": "^5.91.3",
    "@types/pg": "^8.18.0",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.16",
    "next-auth": "^4.24.13",
    "openai": "^4.73.1",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^10.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.16",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "knip": "^6.0.1",
    "pg-mem": "^3.0.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}